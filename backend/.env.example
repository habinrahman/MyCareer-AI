# Copy to .env. Required: OPENAI_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# SUPABASE_JWT_SECRET, DATABASE_URL
#
# App
APP_NAME=MyCareer AI API
# Use APP_ENV or ENVIRONMENT (either maps to the same setting)
APP_ENV=development
DEBUG=true
# Safe auth header logging (length + 16-char prefix; never full token). Or set LOG_LEVEL=DEBUG.
LOG_AUTH_HEADERS=false
LOG_LEVEL=INFO
LOG_JSON=false
SENTRY_DSN=

# CORS (comma-separated). Add your production origin, e.g. https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: browser app origin for PDF QR (same as Next.js URL, no trailing slash)
# PUBLIC_APP_URL=http://localhost:3000

# Rate limiting (SlowAPI; disabled by default for local dev)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=120/minute

GZIP_MINIMUM_SIZE=512
RESPONSE_CACHE_MAX_AGE_SECONDS=0
REQUEST_ID_HEADER=X-Request-ID
MAX_UPLOAD_BYTES=8388608

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_PROMPT_VERSION=v1

# Supabase (server)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Optional reference only (browser uses anon key); backend uses service role for Storage/DB admin tasks
# Optional on server; same as frontend anon key if you want one .env
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings_api
SUPABASE_RESUMES_BUCKET=resumes
SUPABASE_REPORTS_BUCKET=reports
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Postgres (Supabase transaction pooler recommended for server apps)
# postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres
#
# TLS: staging/production always verify the server certificate hostname. In APP_ENV=development,
# hostname verification is off by default. Use either:
# DATABASE_SSL_VERIFY_HOSTNAME=true
# DATABASE_SSL_VERIFY=true
#
# Keep TLS for remote Postgres (Supabase). Only disable for special local tunnels (not recommended):
# DATABASE_SSL_REQUIRED=false
#
# Last resort on Windows / TLS inspection when verify fails (DEVELOPMENT ONLY; ignored if APP_ENV≠development):
# DATABASE_SSL_INSECURE=true
#
# TLS trust: OS store (create_default_context) + Mozilla roots via certifi by default
# (DATABASE_SSL_USE_CERTIFI=true). If verify fails behind TLS inspection, set:
# DATABASE_SSL_CAFILE=C:\path\to\custom-ca-bundle.pem
# To disable certifi merge (OS + optional DATABASE_SSL_CAFILE only):
# DATABASE_SSL_USE_CERTIFI=false
#
# Optional pool / connect tuning (defaults are fine for most deployments)
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_RECYCLE=1800
# DATABASE_POOL_TIMEOUT=30
# DATABASE_CONNECT_TIMEOUT=30
