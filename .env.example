# =============================================================================
# Root .env — used by docker compose (build args + Nginx hostnames).
# Copy to .env on the Droplet: cp .env.example .env
# =============================================================================

# Public URLs (must match DNS and TLS certificate hostnames)
APP_HOST=app.example.com
API_HOST=api.example.com

# Let's Encrypt — email for registration and expiry notices
LETSENCRYPT_EMAIL=you@example.com

# Next.js build-time (browser) — API must be reachable from users' browsers
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_API_URL=https://api.example.com

# -----------------------------------------------------------------------------
# Optional: local Postgres profile (docker compose --profile local-db up -d)
# -----------------------------------------------------------------------------
POSTGRES_USER=mycareer
POSTGRES_PASSWORD=mycareer_dev
POSTGRES_DB=mycareer
POSTGRES_PORT=54322
